---
import BaseLayout from '../layouts/BaseLayout.astro';
import { addressFull, addressShort, googleMapsUrl, osmEmbedUrl, osmLargeMapUrl } from '../config/site';
const b = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<BaseLayout
  title="About"
  description="UW Court – 10-bedroom UW student group rental a few blocks from the University of Washington. Four bathrooms, two kitchens, ~3,100 sq ft, furnished common areas, private backyard deck, and off-street parking."
  image="/images/exterior-side.jpg"
>

  <div class="page-header">
    <div class="container">
      <h1>About UW Court</h1>
      <span class="page-header__sub">{addressShort} · A few blocks from UW Campus</span>
    </div>
  </div>

  <!-- LOCATION -->
  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 style="color:var(--uw-purple);">Prime Location</h2>
          <div class="gold-bar" style="margin-left:0;"></div>
          <p>
            UW Court is located at <strong>{addressFull}</strong>
            — just a few blocks from the University of Washington main campus.
            &nbsp;<a href={googleMapsUrl} target="_blank" rel="noopener" style="font-size:0.88rem;">→ View on Map</a>
          </p>
          <p>
            UW Court is a <strong>group rental for UW students</strong> — roughly 3,100 sq ft of living space spread across three floors, with enough room, bathrooms, and common areas for a full group to live comfortably.
          </p>
          <ul style="margin:0.5rem 0 1.25rem 1.5rem; line-height:2.1;">
            <li>10 bedrooms — 4 upstairs, 2 large bedrooms on the main floor, and 4 in the basement (many large enough to be shared)</li>
            <li>4 full bathrooms — 2 upstairs, 1 on the main floor, 1 in the basement (all with shower or shower/tub)</li>
            <li>Two kitchens — main floor and basement, each with a dining area</li>
            <li>Large furnished family room on the main floor (couches, tables, lamps)</li>
            <li>Washer and dryer in the basement</li>
            <li>Gated, private backyard deck — furnished with outdoor furniture</li>
            <li>Two off-street parking spots behind the house (fits up to three small cars)</li>
            <li>Monthly professional cleaning of common areas — at no extra charge</li>
            <li>Year-round landscaping — at no extra charge</li>
          </ul>
          <p style="font-size:0.9rem;">
            <a href="tel:+17606030022">760-603-0022</a> &nbsp;·&nbsp;
            <a href="mailto:uwcourt@gmail.com">uwcourt@gmail.com</a>
          </p>
        </div>
        <div style="display:flex; flex-direction:column; gap:1rem;">
          <img src={`${b}/images/ext-front-3.jpg`} alt="UW Court front exterior"
            style="border-radius:8px; border:3px solid var(--uw-gold-light); width:100%;" loading="lazy" />
          <div class="address-block">
            <h3>Get in Touch</h3>
            <p>{addressFull}</p>
            <p><a href="tel:+17606030022">760-603-0022</a></p>
            <p><a href="mailto:uwcourt@gmail.com">uwcourt@gmail.com</a></p>
          </div>
          <iframe
            src={osmEmbedUrl}
            width="100%" height="280" style="border:0; border-radius:8px; margin-top:1rem; display:block;"
            allowfullscreen loading="lazy">
          </iframe>
          <p style="font-size:0.75rem; text-align:right; margin:0.25rem 0 0; color:var(--text-light);">
            <a href={osmLargeMapUrl} target="_blank" rel="noopener">View larger map</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--gray">
    <div class="container">
      <h2 class="section-heading">Exterior Photos</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid">
        <img src={`${b}/images/ext-back-deck-1.jpg`}   alt="Back deck"               loading="lazy" />
        <img src={`${b}/images/ext-back-deck-2.jpg`}   alt="Back deck with seating"  loading="lazy" />
        <img src={`${b}/images/ext-front-1.jpg`}       alt="Front exterior"          loading="lazy" />
        <img src={`${b}/images/ext-front-2.jpg`}       alt="Front yard"              loading="lazy" />
        <img src={`${b}/images/ext-front-3.jpg`}       alt="Front street view"       loading="lazy" />
        <img src={`${b}/images/ext-front-grass.jpg`}   alt="Front yard landscaping"  loading="lazy" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-heading">Interior Photos</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
        <img src={`${b}/images/dining-area.jpg`}        alt="Dining area"             loading="lazy" />
        <img src={`${b}/images/family-room.jpg`}        alt="Family room"             loading="lazy" />
        <img src={`${b}/images/kitchen-1.jpg`}          alt="Main kitchen"            loading="lazy" />
        <img src={`${b}/images/kitchen-2.jpg`}          alt="Second kitchen"          loading="lazy" />
        <img src={`${b}/images/laundry-room.jpg`}       alt="Laundry room"            loading="lazy" />
        <img src={`${b}/images/staircase.jpg`}          alt="Staircase"               loading="lazy" />
        <img src={`${b}/images/hallway.jpg`}            alt="Hallway"                 loading="lazy" />
        <img src={`${b}/images/study-area.jpg`}         alt="Study area"              loading="lazy" />
        <img src={`${b}/images/bedroom-3.jpg`}          alt="Bedroom 3"               loading="lazy" />
        <img src={`${b}/images/bedroom-4.jpg`}          alt="Bedroom 4"               loading="lazy" />
        <img src={`${b}/images/bedroom-6.jpg`}          alt="Bedroom 6"               loading="lazy" />
        <img src={`${b}/images/bedroom-8.jpg`}          alt="Bedroom 8"               loading="lazy" />
        <img src={`${b}/images/bedroom-9.jpg`}          alt="Bedroom 9"               loading="lazy" />
        <img src={`${b}/images/bedroom-10.jpg`}         alt="Bedroom 10"              loading="lazy" />
        <img src={`${b}/images/additional-bedroom.jpg`} alt="Additional bedroom"       loading="lazy" />
        <img src={`${b}/images/basement-bedroom.jpg`}   alt="Basement bedroom"        loading="lazy" />
        <img src={`${b}/images/bathroom-1.jpg`}         alt="Bathroom 1"              loading="lazy" />
        <img src={`${b}/images/bathroom-2.jpg`}         alt="Bathroom 2"              loading="lazy" />
        <img src={`${b}/images/bathroom-3.jpg`}         alt="Bathroom 3"              loading="lazy" />
        <img src={`${b}/images/bathroom-4.jpg`}         alt="Bathroom 4"              loading="lazy" />
        <img src={`${b}/images/basement-bath.jpg`}      alt="Basement bathroom"       loading="lazy" />
        <img src={`${b}/images/basement-common.jpg`}    alt="Basement common area"    loading="lazy" />
        <img src={`${b}/images/storage-area.jpg`}       alt="Storage area"            loading="lazy" />
      </div>
    </div>
  </section>

  <!-- UNIVERSITY OF WASHINGTON -->
  <section class="section">
    <div class="container">
      <h2 class="section-heading">University of Washington</h2>
      <div class="gold-bar"></div>
      <div class="photo-grid">
        <img src={`${b}/images/uw-blossoms.jpg`}        alt="UW cherry blossoms"      loading="lazy" />
        <img src={`${b}/images/uw-campus.jpg`}          alt="UW campus"               loading="lazy" />
        <img src={`${b}/images/uw-library.jpg`}         alt="UW library"              loading="lazy" />
      </div>
    </div>
  </section>

  <div class="cta-strip">
    <div class="container">
      <h2>Interested in Renting UW Court?</h2>
      <p>Contact us today or fill out our online application to get started.</p>
      <a href={`${b}/apply`} class="btn btn--gold">Apply Now</a>
      &nbsp;&nbsp;
      <a href={`${b}/lease-process`} class="btn btn--outline-white">Lease Process</a>
    </div>
  </div>

</BaseLayout>
