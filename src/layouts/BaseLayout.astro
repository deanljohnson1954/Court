---
import '../styles/global.css';
import { address, addressFull } from '../config/site';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const { title, description, image = '/images/backyard2.jpg', canonicalUrl, noindex = false } = Astro.props;

// Normalize base: always no trailing slash  e.g. "/Court"
const b = import.meta.env.BASE_URL.replace(/\/+$/, '');

const siteTitle = 'UW Court – 10-Bedroom Student Group Rental, Seattle';
const fullTitle = title === 'Home' ? siteTitle : `${title} | UW Court`;
const siteUrl = Astro.site!.origin;
// Normalize to trailing slash to match GitHub Pages directory serving (page/index.html → /page/)
const normalizedPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonical = canonicalUrl ?? new URL(normalizedPath, Astro.site).toString();
const ogImage = new URL(image, Astro.site).toString();

const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta name="author" content="UW Court" />
    <meta name="keywords" content="UW Court, UW student housing, University of Washington housing, group rental Seattle, student house rental Seattle, off-campus UW housing, 5031 19th Ave NE Seattle, UW off-campus housing, Seattle student rental, student group rental near UW, university district student housing" />
    <meta name="geo.region" content="US-WA" />
    <meta name="geo.placename" content="Seattle, Washington" />
    <meta name="geo.position" content="47.6657;-122.3055" />
    <meta name="ICBM" content="47.6657, -122.3055" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="UW Court" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["ApartmentComplex", "LodgingBusiness"],
      "name": "UW Court",
      "description": "10-bedroom student group rental house near the University of Washington in Seattle, WA. ~3,100 sq ft across three floors with 4 bathrooms, two kitchens, furnished common areas, private backyard deck, and off-street parking.",
      "url": siteUrl,
      "logo": `${siteUrl}/favicon.svg`,
      "image": `${siteUrl}/images/ext-front-3.jpg`,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": address.street,
        "addressLocality": address.city,
        "addressRegion": address.state,
        "postalCode": address.zip,
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 47.6657,
        "longitude": -122.3055
      },
      "telephone": "+1-760-603-0022",
      "email": "uwcourt@gmail.com",
      "numberOfRooms": 10,
      "amenityFeature": [
        { "@type": "LocationFeatureSpecification", "name": "10 Bedrooms", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "4 Full Bathrooms", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Two Kitchens", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "In-Unit Washer/Dryer", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Private Backyard Deck", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Off-Street Parking", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Furnished Common Areas", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Monthly Professional Cleaning", "value": true },
        { "@type": "LocationFeatureSpecification", "name": "Year-Round Landscaping", "value": true }
      ],
      "knowsAbout": "University of Washington student housing",
      "areaServed": {
        "@type": "City",
        "name": "Seattle",
        "sameAs": "https://www.wikidata.org/wiki/Q5083"
      }
    })} />
    <link rel="icon" type="image/svg+xml" href={`${b}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>

  <body>
    <header class="site-header" role="banner">
      <div class="container">
        <a class="site-logo" href={`${b}/`} aria-label="UW Court – Home">
          <span class="site-logo__mark"></span>
          <span class="site-logo__text"></span>
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
        <nav class="main-nav" id="mainNav" role="navigation" aria-label="Main navigation">
          <ul>
            <li><a href={`${b}/`}          aria-current={path === `${b}/` || path === b ? 'page' : undefined}>Home</a></li>
            <li><a href={`${b}/about`}     aria-current={path.includes('/about') ? 'page' : undefined}>About</a></li>
            <li><a href={`${b}/lease-process`} aria-current={path.includes('/lease-process') ? 'page' : undefined}>Lease Process</a></li>
            <li><a href={`${b}/apply`}     aria-current={path.includes('/apply') ? 'page' : undefined}>Apply</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main id="main-content"><slot /></main>

    <footer class="site-footer" role="contentinfo">
      <div class="container">
        <div class="footer-logo">UW COURT</div>
        <nav class="footer-nav" aria-label="Footer navigation">
          <ul>
            <li><a href={`${b}/`}>Home</a></li>
            <li><a href={`${b}/about`}>About</a></li>
            <li><a href={`${b}/lease-process`}>Lease Process</a></li>
            <li><a href={`${b}/apply`}>Apply</a></li>
          </ul>
        </nav>
        <hr class="footer-divider" />
        <div class="footer-copy">
          <p>{addressFull} &nbsp;|&nbsp;
            <a href="tel:+17606030022">760-603-0022</a> &nbsp;|&nbsp;
            <a href="mailto:uwcourt@gmail.com">uwcourt@gmail.com</a>
          </p>
          <p>Not owned by or affiliated with the University of Washington.</p>
          <p>&copy; {new Date().getFullYear()} UW Court. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      const toggle = document.getElementById('navToggle');
      const nav = document.getElementById('mainNav');
      toggle?.addEventListener('click', () => {
        const isOpen = nav?.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
    </script>
  </body>
</html>
